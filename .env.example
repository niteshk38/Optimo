# Copy to `.env` and fill in what you use. `.env` is gitignored — never commit it.

# --- Job sources ---
# Free key from https://developer.adzuna.com (leave blank to disable Adzuna).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# RapidAPI key for the JSearch aggregator (Google for Jobs -> LinkedIn/Indeed/etc.).
# Subscribe to "JSearch" at https://rapidapi.com (free Basic plan). Blank = disabled.
RAPIDAPI_KEY=

# Google Programmable Search (Custom Search JSON API) — plain web search for links
# from Instahyre, LinkedIn jobs, Naukri, etc. Free for 100 searches/day.
#   Key:  Google Cloud console, enable "Custom Search API", create an API key.
#   CX :  programmablesearchengine.google.com, make an engine set to the ENTIRE WEB,
#         copy its "Search engine ID". Both blank = disabled.
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# --- LLM ---
# Leave these unset to use the local Ollama default (http://localhost:11434/v1).
# For a hosted, OpenAI-compatible provider, set all three, e.g.:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Serper.dev web search (Instahyre/LinkedIn/Naukri links) — free tier, one key.
# Get it at https://serper.dev -> API Key. Used by the 'websearch' source.
SERPER_API_KEY=
